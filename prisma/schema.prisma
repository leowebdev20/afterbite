generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Confidence {
  LOW
  MEDIUM
  HIGH
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  OTHER
}

model User {
  id           String                   @id @default(cuid())
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  meals        Meal[]
  symptomLogs  SymptomLog[]
  recipes      Recipe[]
  snapshots    IngredientImpactSnapshot[]
  settings     UserSettings?
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  timeZone  String
  reminderTimes Json?
  age       Int?
  heightCm  Int?
  weightKg  Int?
  caloriesGoal Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id           String                   @id @default(cuid())
  name         String                   @unique
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  mealItems    MealItem[]
  recipeItems  RecipeItem[]
  snapshots    IngredientImpactSnapshot[]
}

model Meal {
  id         String     @id @default(cuid())
  userId     String
  name       String
  mealType   MealType   @default(OTHER)
  eatenAt    DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      MealItem[]

  @@index([userId, eatenAt])
}

model MealItem {
  id            String      @id @default(cuid())
  mealId        String
  ingredientId  String
  quantity      Float?
  meal          Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  ingredient    Ingredient  @relation(fields: [ingredientId], references: [id])

  @@index([mealId])
  @@index([ingredientId])
}

model SymptomLog {
  id         String         @id @default(cuid())
  userId     String
  loggedAt   DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries    SymptomEntry[]

  @@index([userId, loggedAt])
}

model SymptomEntry {
  id           String      @id @default(cuid())
  symptomLogId String
  symptom      String
  severity     Int
  symptomLog   SymptomLog  @relation(fields: [symptomLogId], references: [id], onDelete: Cascade)

  @@index([symptomLogId])
}

model Recipe {
  id         String       @id @default(cuid())
  userId     String
  name       String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      RecipeItem[]

  @@index([userId, updatedAt])
}

model RecipeItem {
  id            String      @id @default(cuid())
  recipeId      String
  ingredientId  String
  quantity      Float?
  recipe        Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient    Ingredient  @relation(fields: [ingredientId], references: [id])

  @@index([recipeId])
  @@index([ingredientId])
}

model IngredientImpactSnapshot {
  id            String      @id @default(cuid())
  userId        String
  ingredientId  String
  impactScore   Float
  confidence    Confidence
  sampleSize    Int
  symptom       String
  computedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient    Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([userId, ingredientId, computedAt])
}
